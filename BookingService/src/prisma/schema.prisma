generator client {
  provider = "prisma-client"
  output   = "../prisma/generated"
}

datasource db {
  provider = "mysql"
}

model Booking {
  id                String        @id @default(cuid())
  userId            String
  hotelId           String
  bookingPrice      Float
  bookingStatus     BookingStatus @default(PENDING)
  totalGuests       Int
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  idempotencyKeyId  String?     @unique
  idempotencyKey    Idempotency?  @relation(fields: [idempotencyKeyId], references: [id])
}

model Idempotency{
  id            String   @id @default(cuid())
  bookingId     String   @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  booking       Booking?  
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}
